# ─── Financial Analysis Agent — Environment Variables ───────────────
# Copy this file to .env and fill in your API keys.
# Claude Code is the LLM layer — no LLM API keys needed here.

# ─── Twitter API ────────────────────────────────────────────────────
# TwitterAPI.io credentials for Twitter/X search and monitoring.
# Get your key from: https://twitterapi.io
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here

# ─── Web Search (Tavily — optional but recommended) ────────────────
# AI-agent-optimized search with relevance scoring.
# Falls back to DuckDuckGo (free, no key needed) if not set.
# Get your key from: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── FRED API ───────────────────────────────────────────────────────
# Federal Reserve Economic Data API (free)
# Get your key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── IBKR Gateway ─────────────────────────────────────────────
# IB Gateway connection (for market data + news streaming)
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=1
IB_NEWS_CLIENT_ID=10

# ─── News Streaming Providers ─────────────────────────────────
# Finnhub (free tier: 60 req/min, WebSocket for 50 symbols)
# Get your key from: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Benzinga (free tier: headlines + teasers)
# Get your key from: Benzinga developer portal
BENZINGA_API_KEY=your_benzinga_api_key_here

# finlight.me (free tier: 5K req/mo, 12-hr delay)
# Get your key from: https://app.finlight.me
FINLIGHT_API_KEY=your_finlight_api_key_here
