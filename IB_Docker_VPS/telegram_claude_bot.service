[Unit]
Description=Telegram Claude Code Financial Agent Bot
After=network.target docker.service
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/root/Finl_Agent_CC
ExecStart=/usr/bin/python3 /root/Finl_Agent_CC/telegram_claude_bot.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
